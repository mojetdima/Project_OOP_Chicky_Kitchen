@model RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<section class="page-header">
    <span class="eyebrow">Registration</span>
    <h1>Create your Chicky Kitchen account</h1>
    <p>Register to view profile details and make reservations online.</p>
</section>

<section class="form-panel">
    <form asp-action="Register" method="post">
        <div asp-validation-summary="ModelOnly" class="text-warning mb-3"></div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Login" class="form-label"></label>
                <input asp-for="Login" class="form-control" />
                <span asp-validation-for="Login" class="text-warning"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" />
                <span asp-validation-for="Password" class="text-warning"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-warning"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="Surname" class="form-label"></label>
                <input asp-for="Surname" class="form-control" />
                <span asp-validation-for="Surname" class="text-warning"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="Age" class="form-label"></label>
                <input asp-for="Age" class="form-control" />
                <span asp-validation-for="Age" class="text-warning"></span>
            </div>
            <div class="col-md-6 mb-4">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-warning"></span>
            </div>
        </div>
        <button type="submit" class="btn btn-brand">Register</button>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

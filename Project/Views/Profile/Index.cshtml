@model ProfileViewModel
@{
    ViewData["Title"] = "Profile";
}

<section class="page-header">
    <span class="eyebrow">Profile</span>
    <h1>@Model.User.Name @Model.User.Surname</h1>
    <p>Personal info, reservation list, and order history.</p>
</section>

<section class="profile-layout">
    <article class="info-card">
        <h2>Personal information</h2>
        <dl class="profile-list">
            <div><dt>Login</dt><dd>@Model.User.Login</dd></div>
            <div><dt>Email</dt><dd>@Model.User.Email</dd></div>
            <div><dt>Age</dt><dd>@Model.User.Age</dd></div>
        </dl>
    </article>

    <article class="info-card">
        <div class="section-title">
            <h2>Reservations</h2>
            <a class="btn btn-sm btn-brand" asp-action="CreateReservation">Add reservation</a>
        </div>
        @if (Model.Reservations.Any())
        {
            <div class="table-responsive">
                <table class="table table-dark table-striped align-middle">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Table</th>
                            <th>Guests</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var reservation in Model.Reservations)
                        {
                            <tr>
                                <td>@reservation.Date.ToString("dd.MM.yyyy HH:mm")</td>
                                <td>@reservation.TableNumber</td>
                                <td>@reservation.AmountOfGuests</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p>No reservations yet.</p>
        }
    </article>

    <article class="info-card">
        <h2>History</h2>
        @if (Model.History.Any())
        {
            <ul class="plain-list">
                @foreach (var item in Model.History)
                {
                    <li>@item.DishName, table @item.TableNumber</li>
                }
            </ul>
        }
        else
        {
            <p>No order history yet.</p>
        }
    </article>
</section>

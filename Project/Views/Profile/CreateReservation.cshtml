@model ReservationCreateViewModel
@{
    ViewData["Title"] = "New Reservation";
}

<section class="page-header">
    <span class="eyebrow">Reservation</span>
    <h1>Create a reservation</h1>
    <p>Select a date, table number, and guest count.</p>
</section>

<section class="form-panel">
    <form asp-action="CreateReservation" method="post">
        <div asp-validation-summary="ModelOnly" class="text-warning mb-3"></div>
        <div class="mb-3">
            <label asp-for="Date" class="form-label"></label>
            <input asp-for="Date" class="form-control" />
            <span asp-validation-for="Date" class="text-warning"></span>
        </div>
        <div class="mb-3">
            <label asp-for="TableNumber" class="form-label"></label>
            <input asp-for="TableNumber" class="form-control" />
            <span asp-validation-for="TableNumber" class="text-warning"></span>
        </div>
        <div class="mb-4">
            <label asp-for="AmountOfGuests" class="form-label"></label>
            <input asp-for="AmountOfGuests" class="form-control" />
            <span asp-validation-for="AmountOfGuests" class="text-warning"></span>
        </div>
        <button type="submit" class="btn btn-brand">Save reservation</button>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
